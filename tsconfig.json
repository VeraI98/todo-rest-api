{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": true,

        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "baseUrl": "./src",

        "paths": {
            "@/*": ["*"]
        },

        "types": ["node"]
    },

    "include": ["src"],

    "exclude": ["node_modules", "dist"]
}